---
import BaseLayout from "../layouts/BaseLayout.astro";
const base = import.meta.env.BASE_URL;
---

<BaseLayout title="الصفحة غير موجودة - بنيان" description="عذرًا، الصفحة التي تبحث عنها غير موجودة.">
  <main id="main-content" class="flex flex-col items-center justify-center min-h-[80vh] px-6 text-center mx-auto w-full max-w-5xl">
    <h1 class="text-8xl md:text-9xl font-black tracking-tighter text-gray-900 mb-4">404</h1>
    <p class="text-xl md:text-2xl text-zinc-600 mb-8">عذرًا، الصفحة التي تبحث عنها غير موجودة.</p>
    <a
      href={base}
      class="inline-flex items-center gap-3 px-8 py-4 rounded-full bg-ngreen text-black font-bold text-sm transition-all duration-300 hover:bg-lime-400 hover:scale-105"
    >
      <svg class="-scale-x-100" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M5 12h14"/><path d="M12 5l7 7-7 7"/>
      </svg>
      العودة إلى الصفحة الرئيسية
    </a>
  </main>
</BaseLayout>
