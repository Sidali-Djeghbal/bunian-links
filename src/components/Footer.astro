---
import fa7 from "@iconify-json/fa7-brands/icons.json";

function makeSvg(id) {
  const meta = fa7.icons?.[id];
  if (!meta) return "";
  const w = meta.width || 24;
  const h = meta.height || 24;
  return `<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"18\" height=\"18\" viewBox=\"0 0 ${w} ${h}\">${meta.body}</svg>`;
}

const today = new Date();

const socialLinks = [
  { name: "فيسبوك", iconId: "facebook", url: "https://www.facebook.com/BunianFoundation", color: "hover:bg-blue-500/10" },
  { name: "إنستغرام", iconId: "instagram", url: "https://www.instagram.com/bunian.ar?igsh=MWxsM2sydzFqbWEyYg==", color: "hover:bg-pink-500/10" },
  { name: "تليجرام", iconId: "telegram", url: "https://t.me/Algerianspositivevibes", color: "hover:bg-green-400/10" },
  { name: "يوتيوب", iconId: "youtube", url: "https://youtube.com/channel/UCIfXPqovW2lulgVg49qh4Rw", color: "hover:bg-red-500/10" },
  { name: "لينكد إن", iconId: "linkedin", url: "https://www.linkedin.com/company/bunian-%D8%A8%D9%86%D9%8A%D8%A7%D9%86/", color: "hover:bg-blue-600/10" },
  { name: "ساوندكلاود", iconId: "soundcloud", url: "https://soundcloud.com/user-677669497-573369962", color: "hover:bg-orange-500/10" },
];
---

<footer class="relative">
  <div
    class="absolute h-px left-1/2 -translate-x-1/2 w-3/5 bg-gradient-to-r from-transparent to-transparent via-lime-500 top-0 opacity-40"
  >
  </div>

  <div class="social-links">
    {socialLinks.map((link) => (
      <a href={link.url} target="_blank" rel="noreferrer" class={`social-link ${link.color}`}>
        <span class="sr-only">{link.name}</span>
        <span aria-hidden="true" set:html={makeSvg(link.iconId)} />
      </a>
    ))}
  </div>
  <p class="opacity-70 mt-8 text-base">
    &copy; {today.getFullYear()} بنيان. جميع الحقوق محفوظة.
  </p>
</footer>
<style>
  footer {
    padding: 1.25em 1em 2.25em 1em;
    text-align: center;
  }
  .social-links {
    display: flex;
    justify-content: center;
    gap: 1.2em;
    margin-top: 1em;
  }
  .social-links a {
    display: inline-grid;
    place-items: center;
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 9999px;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(var(--gray-dark), 0.95);
    text-decoration: none;
    opacity: 0.8;
    color: rgb(var(--white));
    transition:
      opacity 0.2s ease,
      transform 0.2s ease,
      border-color 0.2s ease,
      background-color 0.2s ease,
      color 0.2s ease;
  }
  .social-links a:hover {
    opacity: 1;
    transform: translateY(-2px);
    border-color: rgba(168, 229, 36, 0.5);
    background: rgb(24, 28, 25);
    color: rgb(168, 229, 36);
  }
  .social-links svg {
    display: block;
    width: 18px;
    height: 18px;
    flex: none;
  }
</style>
